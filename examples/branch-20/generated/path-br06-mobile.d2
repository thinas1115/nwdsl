s_br06.n_br06_sw01 -> s_br06.n_br06_rt01: "①" {class: edge-lan-cable; source-arrowhead.label: "Gi0/1"; target-arrowhead.label: "Gi0/1"; style.stroke: "#c5221f"; style.stroke-width: 4; style.animated: true}
lbl_13: "NTT Com IP-VPN 100M\n(Gi0/2)" {class: edge-label; style.opacity: 0.5}
n_ipvpn -- lbl_13 {class: edge-wan-circuit; style.stroke: "#c5221f"; style.stroke-dash: 4; style.opacity: 0.55}
