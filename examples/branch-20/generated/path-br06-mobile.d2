n_br12_rt01: "br12-rt01\n(支店12)" {class: node-external; style.opacity: 0.3}
n_br13_rt01: "br13-rt01\n(支店13)" {class: node-external; style.opacity: 0.3}
n_br14_rt01: "br14-rt01\n(支店14)" {class: node-external; style.opacity: 0.3}
n_br15_rt01: "br15-rt01\n(支店15)" {class: node-external; style.opacity: 0.3}
n_br16_rt01: "br16-rt01\n(支店16)" {class: node-external; style.opacity: 0.3}
n_br17_rt01: "br17-rt01\n(支店17)" {class: node-external; style.opacity: 0.3}
n_br18_rt01: "br18-rt01\n(支店18)" {class: node-external; style.opacity: 0.3}
n_br19_rt01: "br19-rt01\n(支店19)" {class: node-external; style.opacity: 0.3}
n_br20_rt01: "br20-rt01\n(支店20)" {class: node-external; style.opacity: 0.3}

s_hube.n_hube_rt01 -- s_hube.n_hube_core01 {class: edge-lan-cable; source-arrowhead.label: "Gi0/1"; target-arrowhead.label: "Gi0/1"; style.opacity: 0.15}
s_hube.n_hube_rt02 -> s_hube.n_hube_core01: "④" {class: edge-lan-cable; source-arrowhead.label: "Gi0/1"; target-arrowhead.label: "Gi0/2"; style.stroke: "#c5221f"; style.stroke-width: 4; style.animated: true}
s_hube.n_hube_core01 -> s_hube.n_hube_srv01: "⑤" {class: edge-lan-cable; source-arrowhead.label: "Gi0/3"; target-arrowhead.label: "Gi0/1"; style.stroke: "#c5221f"; style.stroke-width: 4; style.animated: true}
lbl_3: "NTT Com IP-VPN 1G\n(Gi0/2)" {class: edge-label; style.opacity: 0.15}
n_ipvpn -- lbl_3 {class: edge-wan-circuit; style.opacity: 0.15}
lbl_3 -- s_hube.n_hube_rt01 {class: edge-wan-circuit; style.opacity: 0.15}
lbl_4: "NTT Com IP-VPN 1G\n(Gi0/2)" {class: edge-label; style.opacity: 0.15}
n_ipvpn -- lbl_4 {class: edge-wan-circuit; style.opacity: 0.15}
lbl_4 -- s_hube.n_hube_rt02 {class: edge-wan-circuit; style.opacity: 0.15}
lbl_5: "③" {class: edge-label; style.font-color: "#c5221f"; style.bold: true}
n_mobile -- lbl_5 {class: edge-wan-circuit; style.stroke: "#c5221f"; style.stroke-width: 4; style.animated: true}
lbl_5 -> s_hube.n_hube_rt02 {class: edge-wan-circuit; style.stroke: "#c5221f"; style.stroke-width: 4; style.animated: true}
n_ipvpn -- s_hube.n_hube_rt01: "BGP" {class: edge-logical; style.opacity: 0.15}
n_ipvpn -- n_br03_rt01 {class: edge-logical; style.opacity: 0.15}
