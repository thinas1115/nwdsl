  n_hq_acc07: "hq-acc07\nCatalyst 1000" {class: role-l2switch}
  n_hq_acc08: "hq-acc08\nCatalyst 1000" {class: role-l2switch}
  n_hq_acc09: "hq-acc09\nCatalyst 1000" {class: role-l2switch}
  n_hq_acc10: "hq-acc10\nCatalyst 1000" {class: role-l2switch}
  n_hq_srvsw01: "hq-srvsw01\nCatalyst 9200" {class: role-l2switch; width: 270}
  n_hq_srvsw02: "hq-srvsw02\nCatalyst 9200" {class: role-l2switch; width: 180}
  n_hq_srv01: "hq-srv01\nPowerEdge R660" {class: role-other}
  n_hq_srv02: "hq-srv02\nPowerEdge R660" {class: role-other}
  n_hq_srv03: "hq-srv03\nPowerEdge R660" {class: role-other}
  n_hq_srv04: "hq-srv04\nPowerEdge R660" {class: role-other}
  n_hq_dmzsw01: "hq-dmzsw01\nCatalyst 1000" {class: role-l2switch; width: 180}
  n_hq_dmzsrv01: "hq-dmzsrv01\n公開Web" {class: role-other}
  n_hq_dmzsrv02: "hq-dmzsrv02\n公開DNS" {class: role-other}
}

n_ipvpn: "　IP-VPN網　" {class: node-cloud}
n_internet: "　インターネット　" {class: node-cloud}

