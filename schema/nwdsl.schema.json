{
  "$defs": {
    "Circuit": {
      "additionalProperties": false,
      "description": "キャリア回線契約。結線 (link) とは分離して契約情報を保持する。",
      "properties": {
        "id": {
          "description": "回線ID (ファイル内で一意)",
          "title": "Id",
          "type": "string"
        },
        "provider": {
          "description": "回線事業者",
          "title": "Provider",
          "type": "string"
        },
        "service": {
          "description": "サービス名 (例: IP-VPN, フレッツ光ネクスト)",
          "title": "Service",
          "type": "string"
        },
        "circuit_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "事業者発行の回線番号",
          "title": "Circuit Id"
        },
        "bandwidth": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "契約帯域 (例: 100M, 1G)",
          "title": "Bandwidth"
        },
        "status": {
          "default": "active",
          "description": "回線の状態",
          "enum": [
            "planned",
            "active",
            "decommissioned"
          ],
          "title": "Status",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        }
      },
      "required": [
        "id",
        "provider",
        "service"
      ],
      "title": "Circuit",
      "type": "object"
    },
    "Cloud": {
      "additionalProperties": false,
      "description": "事業者網・外部網 (IP-VPN網、インターネット等)。link の端点に指定できる。",
      "properties": {
        "id": {
          "description": "網ID (devices と合わせて一意)",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "description": "網の表示名",
          "title": "Name",
          "type": "string"
        },
        "kind": {
          "default": "wan",
          "description": "網の種別",
          "enum": [
            "wan",
            "internet",
            "other"
          ],
          "title": "Kind",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "Cloud",
      "type": "object"
    },
    "Device": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "機器ID (clouds と合わせて一意)",
          "title": "Id",
          "type": "string"
        },
        "site": {
          "description": "設置拠点ID (sites を参照)",
          "title": "Site",
          "type": "string"
        },
        "role": {
          "default": "other",
          "description": "機器の役割 (図の配色・表の分類に使用)",
          "enum": [
            "router",
            "l3switch",
            "l2switch",
            "firewall",
            "loadbalancer",
            "wlc",
            "ap",
            "server",
            "other"
          ],
          "title": "Role",
          "type": "string"
        },
        "platform": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "機種・型番",
          "title": "Platform"
        },
        "mgmt_ipv4": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "管理IPアドレス (CIDR形式)",
          "title": "Mgmt Ipv4"
        },
        "redundancy_group": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "冗長グループ名 (HSRP/VRRPペア・スタック等で同名を指定)",
          "title": "Redundancy Group"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        },
        "interfaces": {
          "description": "インターフェース定義",
          "items": {
            "$ref": "#/$defs/Interface"
          },
          "title": "Interfaces",
          "type": "array"
        }
      },
      "required": [
        "id",
        "site"
      ],
      "title": "Device",
      "type": "object"
    },
    "Interface": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "インターフェース名 (機器内で一意。例: Gi0/0/1, eth0, Tunnel0)",
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "用途説明",
          "title": "Description"
        },
        "ipv4": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IPv4アドレス (CIDR形式)",
          "title": "Ipv4"
        },
        "segment": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "所属セグメントID (segments を参照)",
          "title": "Segment"
        }
      },
      "required": [
        "name"
      ],
      "title": "Interface",
      "type": "object"
    },
    "Link": {
      "additionalProperties": false,
      "description": "機器間・機器-網間の接続。type が線の意味を決める。\n\nendpoints の記法:\n  - \"device-id:interface-name\" … 機器のIF (lan-cable / wan-circuit では必須)\n  - \"device-id\"                … 機器そのもの (logical / tunnel で許可)\n  - \"cloud-id\"                 … 網 (wan-circuit でのみ許可)",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "接続ID (省略可。指定時は一意)",
          "title": "Id"
        },
        "type": {
          "description": "接続の種別 (線の意味)",
          "enum": [
            "lan-cable",
            "wan-circuit",
            "logical",
            "tunnel"
          ],
          "title": "Type",
          "type": "string"
        },
        "endpoints": {
          "description": "両端点",
          "items": {
            "type": "string"
          },
          "maxItems": 2,
          "minItems": 2,
          "title": "Endpoints",
          "type": "array"
        },
        "circuit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "経由する回線契約ID (wan-circuit では必須、他typeでは指定不可)",
          "title": "Circuit"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足 (logical/tunnel では図のラベルになる)",
          "title": "Description"
        }
      },
      "required": [
        "type",
        "endpoints"
      ],
      "title": "Link",
      "type": "object"
    },
    "NetworkMeta": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "ネットワーク(案件)名",
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "説明",
          "title": "Description"
        }
      },
      "required": [
        "name"
      ],
      "title": "NetworkMeta",
      "type": "object"
    },
    "Path": {
      "additionalProperties": false,
      "description": "通信経路 (正常時/障害時のトラフィックの通り道)。\n\n経路は作成者が明示する (ルーティング計算による自動導出はしない)。\n隣接ホップ間に実在の link があることをバリデータが検査する。",
      "properties": {
        "id": {
          "description": "経路ID (ファイル内で一意)",
          "title": "Id",
          "type": "string"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "経路の表示名",
          "title": "Title"
        },
        "failure": {
          "description": "この経路が前提とする障害コンポーネント (device/cloud/circuit のID)。図で赤✕表示",
          "items": {
            "type": "string"
          },
          "title": "Failure",
          "type": "array"
        },
        "fallback_of": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "正常時経路のID。指定すると当該経路が灰破線で併記される",
          "title": "Fallback Of"
        },
        "hops": {
          "description": "始点から終点までの順序付きホップ列",
          "items": {
            "$ref": "#/$defs/PathHop"
          },
          "minItems": 2,
          "title": "Hops",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        }
      },
      "required": [
        "id",
        "hops"
      ],
      "title": "Path",
      "type": "object"
    },
    "PathHop": {
      "additionalProperties": false,
      "description": "通信経路の1ホップ。node は devices / clouds の ID。",
      "properties": {
        "node": {
          "description": "ホップのノードID (device または cloud)",
          "title": "Node",
          "type": "string"
        },
        "protocol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "このホップへの到達を決めるプロトコル (例: HSRP, BGP, OSPF)",
          "title": "Protocol"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "経路選択の理由・補足 (図のラベルに表示)",
          "title": "Note"
        }
      },
      "required": [
        "node"
      ],
      "title": "PathHop",
      "type": "object"
    },
    "Segment": {
      "additionalProperties": false,
      "description": "L3セグメント (VLAN / サブネット)。論理構成図とIP設計表の情報源。",
      "properties": {
        "id": {
          "description": "セグメントID (ファイル内で一意)",
          "title": "Id",
          "type": "string"
        },
        "site": {
          "description": "所属拠点ID (sites を参照)",
          "title": "Site",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "セグメント名",
          "title": "Name"
        },
        "vlan": {
          "anyOf": [
            {
              "maximum": 4094,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "VLAN ID",
          "title": "Vlan"
        },
        "ipv4": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ネットワークアドレス (CIDR形式)",
          "title": "Ipv4"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        }
      },
      "required": [
        "id",
        "site"
      ],
      "title": "Segment",
      "type": "object"
    },
    "Site": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "拠点ID (ファイル内で一意)",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "description": "拠点名",
          "title": "Name",
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "所在地",
          "title": "Location"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "Site",
      "type": "object"
    },
    "View": {
      "additionalProperties": false,
      "description": "図の描き分け定義。フィルタと抽象度のみを宣言し、座標・色は持たない。",
      "properties": {
        "id": {
          "description": "ビューID (ファイル内で一意)",
          "title": "Id",
          "type": "string"
        },
        "title": {
          "description": "図のタイトル",
          "title": "Title",
          "type": "string"
        },
        "type": {
          "default": "topology",
          "description": "topology=構成図 / path=経路ハイライト図",
          "enum": [
            "topology",
            "path"
          ],
          "title": "Type",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "type: path のとき対象の経路ID (paths を参照)",
          "title": "Path"
        },
        "layers": {
          "description": "図に含める接続種別",
          "items": {
            "enum": [
              "lan-cable",
              "wan-circuit",
              "logical",
              "tunnel"
            ],
            "type": "string"
          },
          "title": "Layers",
          "type": "array"
        },
        "include_sites": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "この拠点のみ描画 (省略時は全拠点)",
          "title": "Include Sites"
        },
        "exclude_sites": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "除外する拠点",
          "title": "Exclude Sites"
        },
        "collapse_sites": {
          "default": false,
          "description": "true のとき拠点を1ノードに畳む (全社概要図向け)",
          "title": "Collapse Sites",
          "type": "boolean"
        },
        "show_l3": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "L3情報 (IFのIPv4一覧とセグメントノード) を図に表示する。省略時は layers に logical を含むビューで自動的に有効",
          "title": "Show L3"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "補足",
          "title": "Description"
        }
      },
      "required": [
        "id",
        "title"
      ],
      "title": "View",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "DSL ファイル全体。",
  "properties": {
    "nwdsl": {
      "description": "スキーマバージョン (現在は '0.1')",
      "title": "Nwdsl",
      "type": "string"
    },
    "network": {
      "$ref": "#/$defs/NetworkMeta"
    },
    "sites": {
      "items": {
        "$ref": "#/$defs/Site"
      },
      "title": "Sites",
      "type": "array"
    },
    "devices": {
      "items": {
        "$ref": "#/$defs/Device"
      },
      "title": "Devices",
      "type": "array"
    },
    "clouds": {
      "items": {
        "$ref": "#/$defs/Cloud"
      },
      "title": "Clouds",
      "type": "array"
    },
    "circuits": {
      "items": {
        "$ref": "#/$defs/Circuit"
      },
      "title": "Circuits",
      "type": "array"
    },
    "links": {
      "items": {
        "$ref": "#/$defs/Link"
      },
      "title": "Links",
      "type": "array"
    },
    "segments": {
      "items": {
        "$ref": "#/$defs/Segment"
      },
      "title": "Segments",
      "type": "array"
    },
    "paths": {
      "items": {
        "$ref": "#/$defs/Path"
      },
      "title": "Paths",
      "type": "array"
    },
    "views": {
      "items": {
        "$ref": "#/$defs/View"
      },
      "title": "Views",
      "type": "array"
    }
  },
  "required": [
    "nwdsl",
    "network"
  ],
  "title": "Document",
  "type": "object"
}
